{
  "name": "keiki",
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "description": "A Haskell library for the **pure core** of event sourcing, workflow engines, and durable execution, built on a single formalism: the symbolic-register finite-state transducer.",
  "main": "site/build.mjs",
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "scripts": {
    "build": "node site/build.mjs",
    "dev": "pnpm run build && vite site-dist --host 127.0.0.1",
    "preview": "pnpm run build && vite preview site-dist --host 127.0.0.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shinzui/keiki.git"
  },
  "keywords": [],
  "author": "Nadeem Bitar <nadeem@gmail.com>",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/shinzui/keiki/issues"
  },
  "homepage": "https://github.com/shinzui/keiki#readme",
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "beautiful-mermaid": "^1.1.3",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "shiki": "^4.0.2",
    "vite": "^8.0.11"
  }
}
